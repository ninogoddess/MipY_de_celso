{
  "version": 2,
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/scrape_cron",
      "schedule": "0 8 * * 1"
    }
  ],
  "rewrites": [
    { "source": "/api/stats", "destination": "/api/data_engine.py" },
    { "source": "/api/videos", "destination": "/api/data_engine.py" },
    { "source": "/api/classifications", "destination": "/api/data_engine.py" },
    { "source": "/api/painpoints", "destination": "/api/data_engine.py" },
    { "source": "/api/rpm_profile", "destination": "/api/data_engine.py" },
    { "source": "/api/wizard_validate", "destination": "/api/wizard_engine.py" },
    { "source": "/api/wizard_chat", "destination": "/api/wizard_engine.py" },
    { "source": "/api/wizard_process", "destination": "/api/wizard_engine.py" },
    { "source": "/api/mvt", "destination": "/api/mvt.py" },
    { "source": "/api/scrape_cron", "destination": "/api/scrape_cron.py" }
  ]
}
